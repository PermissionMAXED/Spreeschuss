{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cuprum content catalog",
  "description": "Strict schema for catalog/catalog.json. Entries with ids U01..U23 are the binding user-requested contracts (origin=user, required contract_key enforced one-to-one against dev.cuprum.catalogtool.UserContracts; U23 holds global sequence 273 per the CP0C expansion). Additional agent-proposed entries use family ids such as PWR-01 or VFX-01 (origin=additional, contract_key forbidden). Semantic rules a schema cannot express (contract mapping, contiguous sequence, numeric/family-aware id numbering, dependency DAG, origin/tier counts) are enforced by CatalogValidator.",
  "type": "object",
  "additionalProperties": false,
  "required": ["catalog_version", "entries"],
  "properties": {
    "catalog_version": {
      "type": "integer",
      "const": 2
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "sequence", "origin", "family", "name", "type", "tier", "progression_tier", "deps", "vanilla_overlap", "summary", "planned_wave"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^(U[0-9]{2}|[A-Z]{2,5}-[0-9]{2,3})$"
          },
          "sequence": {
            "type": "integer",
            "minimum": 1
          },
          "origin": {
            "type": "string",
            "enum": ["user", "additional"]
          },
          "family": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": ["block", "item", "block_item", "system", "entity", "integration"]
          },
          "tier": {
            "type": "string",
            "enum": ["core", "stretch"]
          },
          "progression_tier": {
            "type": "integer",
            "minimum": 0,
            "maximum": 3
          },
          "deps": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^(U[0-9]{2}|[A-Z]{2,5}-[0-9]{2,3})$"
            }
          },
          "vanilla_overlap": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "planned_wave": {
            "type": "string",
            "pattern": "^W[0-9]+$"
          },
          "contract_key": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          }
        }
      }
    }
  }
}
