{
  "name": "gooby",
  "version": "0.1.0",
  "description": "A portrait-first virtual pet game starring Gooby",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc -b --pretty false",
    "test": "npm run test:unit && npm run test:specialists",
    "test:unit": "vitest run",
    "test:specialists": "node --experimental-strip-types --test scripts/assets/audit-lib.test.mjs src/minigames/*/*.test.mjs",
    "test:e2e": "playwright test",
    "assets:fetch": "node scripts/assets-fetch.mjs",
    "assets:audit": "node scripts/assets-audit.mjs",
    "ci:native-check": "node scripts/native-check.mjs",
    "ci:workflow-check": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "keywords": ["virtual-pet", "three.js", "capacitor"],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "@capacitor/app": "^8.1.1",
    "@capacitor/core": "^8.4.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.2",
    "@capacitor/local-notifications": "^8.2.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.2",
    "@capacitor/status-bar": "^8.0.3",
    "three": "^0.185.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/three": "^0.185.1",
    "eslint": "^10.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
